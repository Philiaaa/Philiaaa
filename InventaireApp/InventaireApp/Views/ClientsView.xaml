<Page x:Class="InventaireApp.Views.ClientsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Clients" Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Clients" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Gérez votre liste de clients"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Nouveau client"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding NouveauCommand}"
                    VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Margin="0,0,16,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="🔍 Rechercher"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding RechercherCommand}"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding Clients}"
                              SelectedItem="{Binding ClientSelectionne}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nom" Binding="{Binding NomComplet}" Width="*"/>
                            <DataGridTextColumn Header="Entreprise" Binding="{Binding Entreprise}" Width="160"/>
                            <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="120"/>
                            <DataGridTextColumn Header="Ville" Binding="{Binding Ville}" Width="110"/>
                            <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}" Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0"
                                Visibility="{Binding ClientSelectionne, Converter={StaticResource NullToVisibility}}">
                        <Button Content="✏️ Modifier" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ModifierCommand}" Margin="0,0,8,0"/>
                        <Button Content="🗑️ Supprimer" Style="{StaticResource DangerButton}"
                                Command="{Binding SupprimerCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Panneau édition -->
            <Border Grid.Column="1" Style="{StaticResource Card}"
                    Visibility="{Binding ModeEdition, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Client" FontSize="16" FontWeight="Bold"
                                   Margin="0,0,0,16" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="PRÉNOM" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditPrenom, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="NOM *" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditNom, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="ENTREPRISE" Style="{StaticResource SectionLabel}"/>
                        <TextBox Text="{Binding EditEntreprise, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="COURRIEL" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="TÉLÉPHONE" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditTelephone, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="ADRESSE" Style="{StaticResource SectionLabel}"/>
                        <TextBox Text="{Binding EditAdresse, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="VILLE" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditVille, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="CODE POSTAL" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditCodePostal, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="NOTES" Style="{StaticResource SectionLabel}"/>
                        <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                 Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <CheckBox IsChecked="{Binding EditActif}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Client actif" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>

                        <Border Background="#FFF3F4" BorderBrush="{StaticResource DangerBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource DangerBrush}" FontSize="13"/>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Sauvegarder" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SauvegarderCommand}" Margin="0,0,8,0"/>
                            <Button Content="Annuler" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AnnulerCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
