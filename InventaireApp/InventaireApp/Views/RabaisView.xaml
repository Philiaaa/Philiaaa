<Page x:Class="InventaireApp.Views.RabaisView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Rabais" Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Rabais" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Configurez les rabais applicables aux commandes"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Nouveau rabais"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding NouveauCommand}"
                    VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Margin="0,0,16,0">
                <DataGrid ItemsSource="{Binding Liste}"
                          SelectedItem="{Binding Selectionne}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                        <DataGridTextColumn Header="%" Binding="{Binding Pourcentage, StringFormat=F2}" Width="80"/>
                        <DataGridTextColumn Header="Début" Binding="{Binding DateDebut, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Fin" Binding="{Binding DateFin, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}" Width="55"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}"
                    Visibility="{Binding ModeEdition, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Rabais" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,16" Foreground="{StaticResource TextPrimaryBrush}"/>

                    <TextBlock Text="NOM *" Style="{StaticResource SectionLabel}"/>
                    <TextBox Text="{Binding EditNom, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="DESCRIPTION" Style="{StaticResource SectionLabel}"/>
                    <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="POURCENTAGE (%)" Style="{StaticResource SectionLabel}"/>
                    <TextBox Text="{Binding EditPourcentage, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="DATE DÉBUT" Style="{StaticResource SectionLabel}"/>
                            <DatePicker SelectedDate="{Binding EditDateDebut}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="DATE FIN" Style="{StaticResource SectionLabel}"/>
                            <DatePicker SelectedDate="{Binding EditDateFin}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <CheckBox IsChecked="{Binding EditActif}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Rabais actif" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>

                    <Border Background="#FFF3F4" BorderBrush="{StaticResource DangerBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource DangerBrush}" FontSize="13"/>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="💾 Sauvegarder" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SauvegarderCommand}" Margin="0,0,8,0"/>
                        <Button Content="Annuler" Style="{StaticResource SecondaryButton}"
                                Command="{Binding AnnulerCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
