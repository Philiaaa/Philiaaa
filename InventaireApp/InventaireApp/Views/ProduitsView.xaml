<Page x:Class="InventaireApp.Views.ProduitsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:InventaireApp.ViewModels"
      Title="Produits" Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Produits" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Gérez votre catalogue de produits"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Nouveau produit"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding NouveauCommand}"
                    VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360" x:Name="PanelColonne"/>
            </Grid.ColumnDefinitions>

            <!-- Liste des produits -->
            <Border Style="{StaticResource Card}" Margin="0,0,16,0">
                <DockPanel>
                    <!-- Barre de recherche -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Column="0" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="🔍 Rechercher"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding RechercherCommand}"/>
                    </Grid>

                    <!-- Grille -->
                    <DataGrid ItemsSource="{Binding Produits}"
                              SelectedItem="{Binding ProduitSelectionne}"
                              DockPanel.Dock="Top">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                            <DataGridTextColumn Header="Prix" Binding="{Binding Prix, StringFormat=C2}" Width="90"/>
                            <DataGridTextColumn Header="Couleur" Binding="{Binding Couleur}" Width="90"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantite}" Width="70"/>
                            <DataGridTextColumn Header="Unité" Binding="{Binding UniteMesure}" Width="80"/>
                            <DataGridCheckBoxColumn Header="Taxes" Binding="{Binding SujetTaxes}" Width="60"/>
                            <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}" Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Actions ligne sélectionnée -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                Margin="0,12,0,0"
                                Visibility="{Binding ProduitSelectionne, Converter={StaticResource NullToVisibility}}">
                        <Button Content="✏️ Modifier" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ModifierCommand}" Margin="0,0,8,0"/>
                        <Button Content="🗑️ Supprimer" Style="{StaticResource DangerButton}"
                                Command="{Binding SupprimerCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Panneau d'édition -->
            <Border Grid.Column="1" Style="{StaticResource Card}"
                    Visibility="{Binding ModeEdition, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Produit" FontSize="16" FontWeight="Bold"
                                   Margin="0,0,0,16" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <TextBlock Text="NOM *" Style="{StaticResource SectionLabel}"/>
                        <TextBox Text="{Binding EditNom, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="DESCRIPTION" Style="{StaticResource SectionLabel}"/>
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                 Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="PRIX ($)" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditPrix, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="STOCK" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditStock, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="COULEUR" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditCouleur, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="UNITÉ DE MESURE" Style="{StaticResource SectionLabel}"/>
                                <TextBox Text="{Binding EditUniteMesure, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox IsChecked="{Binding EditSujetTaxes}" Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Sujet aux taxes QC (TPS 5% + TVQ 9.975%)"
                                       VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <CheckBox IsChecked="{Binding EditActif}" Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Produit actif" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>

                        <!-- Message erreur -->
                        <Border Background="#FFF3F4" BorderBrush="{StaticResource DangerBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="10"
                                Margin="0,0,0,12"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource DangerBrush}" FontSize="13"/>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Sauvegarder" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SauvegarderCommand}" Margin="0,0,8,0"/>
                            <Button Content="Annuler" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AnnulerCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
